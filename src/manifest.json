{
  "manifest_version": 3,
  "name": "Duplicate Tabs Killer",
  "version": "1.0.0",
  "description": "Automatically detect and close duplicate tabs, group and archive tabs.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "tabs",
    "tabGroups",
    "storage",
    "activeTab",
    "unlimitedStorage",
    "contextMenus",
    "favicon",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icons/icon16-action.png",
      "32": "icons/icon32-action.png"
    }
  },
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "options_page": "src/dashboard/index.html"
}
